# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_USERNAME=musecraft
DB_PASSWORD=musecraft1234

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PASSWORD=redis1234

# ── Kafka ─────────────────────────────────────────────────
KAFKA_SERVERS=localhost:9092

# ── JWT ───────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-chars

# ── Claude API ────────────────────────────────────────────
CLAUDE_API_KEY=your-claude-api-key

# ── AWS ───────────────────────────────────────────────────
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
S3_BUCKET=musecraft-assets

# ── Mail ──────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Service Hosts (prod에서 수정) ─────────────────────────
USER_SERVICE_HOST=user-service
BRAND_SERVICE_HOST=brand-service
SUBSCRIPTION_SERVICE_HOST=subscription-service
SETTLEMENT_SERVICE_HOST=settlement-service
NOTIFICATION_SERVICE_HOST=notification-service
